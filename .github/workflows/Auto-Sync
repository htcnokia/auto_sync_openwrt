name: Auto Sync Upstream & Workflow Mod

on:
  schedule:
    # 每天北京时间早上 04:30 自动运行（UTC 20:30）
    # 确保在原作者大部分定时触发的编译脚本跑之前，就把代码和魔改都搞定
    - cron: '30 20 * * *'
  workflow_dispatch: # 保留手动触发按钮

permissions: write-all

jobs:
  sync_and_modify:
    runs-on: ubuntu-latest
    name: Automated Sync and Strict Workflow Trimming

    steps:
    # 1. 【核心改变】使用你的 PAT_TOKEN 来检出仓库，赋予其重写工作流文件的全权
    - name: Checkout target repo with PAT
      uses: actions/checkout@v4
      with:
        ref: main
        token: ${{ secrets.PAT_TOKEN }}
        persist-credentials: true
        fetch-depth: 0

    # 2. 用原生 Git 执行上游 Sync Fork 合并动作
    - name: Fetch and Merge Upstream
      run: |
        git config --global user.name "github-actions[bot]"
        git config --global user.email "github-actions[bot]@users.noreply.github.com"
        
        git remote add upstream https://github.com/VIKINGYFY/OpenWRT-CI.git
        git fetch upstream main
        
        # 使用 standard merge 顺畅融合，本地新增的 Config/PRIVATE.txt 和 Scripts/PRIVATE.sh 绝对不会被冲掉
        git merge upstream/main --allow-unrelated-histories -m "🔄 Auto Sync: Fetch latest upstream" || echo "No remote changes to merge"

    # 3. 【全自动手术刀】既然有了 PAT，直接在这里物理阉割那些烦人的工作流！
    - name: Force Modify Downloaded Workflows
      run: |
        # ① 注释掉 MTK-ALL.yml 的 workflow_run 自动触发
        if [ -f ".github/workflows/MTK-ALL.yml" ]; then
          sed -i '/workflow_run:/,/completed/ {s/^/#/}' .github/workflows/MTK-ALL.yml
          echo "🚫 Disabled auto-trigger for MTK-ALL.yml"
        fi

        # ② 精简 OWRT-ALL.yml 矩阵，只保留 X86 编译
        if [ -f ".github/workflows/OWRT-ALL.yml" ]; then
          # 使用 sed 正则匹配 CONFIG: [...] 并精准替换为 [X86]
          sed -i 's|CONFIG: \[.*\]|CONFIG: \[X86\]|g' .github/workflows/OWRT-ALL.yml
          echo "🎯 Constrained OWRT-ALL.yml matrix to X86 only"
        fi

        # ③ 精简 QCA-ALL.yml 矩阵，让它只编译 IPQ60XX-WIFI-NO
        if [ -f ".github/workflows/QCA-ALL.yml" ]; then
          sed -i 's|CONFIG: \[.*\]|CONFIG: \[IPQ60XX-WIFI-NO\]|g' .github/workflows/QCA-ALL.yml
          echo "🎯 Constrained QCA-ALL.yml matrix to IPQ60XX-WIFI-NO only"
        fi
        
        # ④ 【新增】魔改 Config/GENERAL.txt，强行追加 timecontrol=y 默认开启
        if [ -f "Config/GENERAL.txt" ]; then
          # 检查文件中是否已存在该配置，存在则修改，不存在则追加
          if grep -q "CONFIG_PACKAGE_luci-app-timecontrol" Config/GENERAL.txt; then
            sed -i "s/.*CONFIG_PACKAGE_luci-app-timecontrol.*/CONFIG_PACKAGE_luci-app-timecontrol=y/g" Config/GENERAL.txt
          else
            echo "CONFIG_PACKAGE_luci-app-timecontrol=n" >> Config/GENERAL.txt
          fi
          echo "📝 Added CONFIG_PACKAGE_luci-app-timecontrol=n to Config/GENERAL.txt"
        fi
        
    # 4. 使用 PAT 安全地把合并和魔改后的代码一同 Push 回仓库
    - name: Push Synced & Modified Changes
      run: |
        if [ -n "$(git status --porcelain)" ]; then
          echo "✨ 检测到代码有更新或魔改差异，正在推送到你的 main 分支..."
          git add .
          git commit -m "⚙️ Auto Sync: Workflows successfully trimmed via PAT"
          git push origin main
          echo "✅ 自动同步与工作流裁剪大功告成！"
        else
          echo "🛑 分支状态无变动，已经是最新状态。"
        fi
